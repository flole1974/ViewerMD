<Window x:Class="ViewerMD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ViewerMD" Height="700" Width="1000" MinHeight="400" MinWidth="500">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OnOpen" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit" InputGestureText="Alt+F4"/>
            </MenuItem>
        </Menu>
        <wv2:WebView2 x:Name="WebView"/>
    </DockPanel>
</Window>
